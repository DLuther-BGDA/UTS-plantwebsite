# .env.example
# This file serves as a template for the .env file, which holds environment variables
# for local development. Copy this file to .env and fill in the actual values.

# PostgreSQL Database Credentials for local Docker setup
POSTGRES_USER=flora_database_user
POSTGRES_PASSWORD=your_local_db_password_here

# Full database connection URL for the Flask application.
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/flora_database

# Flask / Flask-Security Secrets - CRITICAL FOR PRODUCTION SECURITY!
# Generate truly random and long strings for these.
# Example: Use `import os; os.urandom(24).hex()` in a Python console.
SECRET_KEY=a_super_long_random_string_for_flask_app_secret
SECURITY_PASSWORD_SALT=another_different_long_random_string_for_password_salt

# Mail Server Configuration
# Provide details for your email sending service (e.g., Gmail, SendGrid).
# For Gmail, MAIL_PASSWORD often requires an "App password" if 2FA is enabled.
MAIL_DEFAULT_SENDER=noreply@example.com # Your application's sender email address
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465 # Common ports: 465 (SSL), 587 (TLS)
MAIL_USE_TLS=False # Set to True if using port 587 with TLS
MAIL_USE_SSL=True # Set to True if using port 465 with SSL
MAIL_USERNAME=your_email_account@example.com
MAIL_PASSWORD=your_email_account_password_or_app_password

# NEW: Secret initial password for first-time user setup
# This is used for creating the first admin user in your application.
# !!! IMPORTANT: CHANGE THIS TO A SECURE, LONG, COMPLEX STRING FOR PRODUCTION !!!
SECRET_INITIAL_PASSWORD=a_very_secret_initial_password_you_must_change